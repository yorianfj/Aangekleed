# --- Database ---
# Lokaal (SQLite, standaard in prisma/schema.prisma):
DATABASE_URL="file:./dev.db"
# Productie (Postgres, bijv. Vercel Postgres / Neon / Supabase):
# DATABASE_URL="postgresql://user:password@host:5432/database"

# --- Stripe ---
# Testsleutels vind je in het Stripe Dashboard onder Developers > API keys.
STRIPE_SECRET_KEY="sk_test_..."
# Webhook signing secret: Developers > Webhooks > jouw endpoint > Signing secret.
STRIPE_WEBHOOK_SECRET="whsec_..."

# --- Resend ---
# API key: https://resend.com/api-keys
RESEND_API_KEY="re_..."
# Verzendadres, moet horen bij een geverifieerd domein in Resend.
MAIL_FROM="AANGEKLEED <noreply@aangekleed.nl>"
# Jouw eigen e-mailadres, ontvangt elke betaalde intake.
OWNER_EMAIL="jij@voorbeeld.nl"

# --- Site ---
# Gebruikt als fallback voor Stripe redirect-URL's als de Origin-header ontbreekt.
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
